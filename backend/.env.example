PORT=5000
NODE_ENV=development
# FIREBASE_SERVICE_ACCOUNT_JSON= (Required)
# FIREBASE_PROJECT_ID= (Required)
JWT_SECRET=replace_with_long_random_secret
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173

# Cloudinary (Required for Production)
CLOUDINARY_CLOUD_NAME=dmoiunaru
CLOUDINARY_API_KEY=289795713964211
CLOUDINARY_API_SECRET=

ADMIN_SEED_EMAIL=admin@liyamu.com
ADMIN_SEED_PASSWORD=Admin@12345

# Firebase Admin SDK (Required for Firestore sync)
# Get this from Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_PROJECT_ID=liyamu
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"liyamu",...}
