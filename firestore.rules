rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ──────────────────────────────────────────────────────

    // Check if the requester is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Check if requester is owner of the document
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // Check if requester has a specific role stored in their own user doc
    function hasRole(role) {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // Check if requester is an admin
    function isAdmin() {
      return hasRole('admin');
    }

    // Prevent clients from directly changing protected fields
    function roleNotChanged() {
      return !('role' in request.resource.data) ||
        request.resource.data.role == resource.data.role;
    }

    // ── Users Collection ──────────────────────────────────────────────────────
    match /users/{uid} {

      // Allow user to read their own document; admins can read any doc
      allow read: if isOwner(uid) || isAdmin();

      // Allow user to create their own document ONLY (backend handles this via Admin SDK)
      // Clients cannot create — this is write-protected; backend uses Admin SDK (bypasses rules)
      allow create: if false;

      // Users can update their own doc but CANNOT change their role
      // Role changes must be done by the backend via Admin SDK
      allow update: if isOwner(uid) && roleNotChanged();

      // Only admins can delete user docs
      allow delete: if isAdmin();
    }

    // ── Books Collection ─────────────────────────────────────────────────────
    match /books/{bookId} {

      // Any authenticated user can read books
      allow read: if isAuth();

      // Only authors and admins can create/update books
      allow create, update: if isAuth() && (
        hasRole('author') ||
        hasRole('verified_author') ||
        hasRole('pro_writer') ||
        isAdmin()
      );

      // Only admins can delete books
      allow delete: if isAdmin();
    }

    // ── Reviews Collection ───────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if isAuth();
      allow create: if isAuth();

      // Only the review author or admin can update/delete
      allow update, delete: if isAuth() && (
        request.auth.uid == resource.data.authorId || isAdmin()
      );
    }

    // ── Notifications Collection ─────────────────────────────────────────────
    match /notifications/{notifId} {
      // Users can only read their own notifications
      allow read: if isAuth() && request.auth.uid == resource.data.userId;
      allow write: if false; // backend only writes notifications
    }

    // ── Admin-only Collections ────────────────────────────────────────────────
    match /creditRequests/{docId} {
      allow read, write: if isAdmin();
    }

    match /withdrawals/{docId} {
      allow read: if isAuth() && (
        request.auth.uid == resource.data.userId || isAdmin()
      );
      allow write: if false; // backend only
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
